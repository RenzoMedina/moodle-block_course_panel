<div class="row">
	{{#courses}}
		<div class="col-md-12">
		<h5 class="card-title">{{fullname}}</h5>
		<p class="card-text mb-0"><span class="text-muted">{{startdatelabel}}</span></p>
		<p class="card-text mb-0"><span class="text-muted">{{enddatelabel}}</span></p>
		<p class="card-text mb-0"><span class="text-{{colors}} font-weight-bold">{{dayslabel}}</span></p>
		</div>
	{{/courses}}
	{{^courses}}
		<p class="blockquote text-muted text-center">{{#str}}nocourses, block_course_panel{{/str}}</p>
	{{/courses}}
</div>
<hr>